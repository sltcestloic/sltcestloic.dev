{
  "name": "sltcestloic.dev",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,client \"npm run server:dev\" \"npm run client:start\"",
    "dev:db": "docker compose -f docker-compose.dev.yml up -d",
    "dev:db:down": "docker compose -f docker-compose.dev.yml down",
    "start": "npm run dev",
    "build": "npm run client:build && npm run server:build",
    "test": "npm run client:test",
    "client:sync-env": "node src/client/scripts/write-environment.mjs",
    "client:start": "npm run client:sync-env && cd src/client && ng serve",
    "client:build": "npm run client:sync-env && cd src/client && ng build",
    "client:watch": "npm run client:sync-env && cd src/client && ng build --watch --configuration development",
    "client:test": "npm run client:sync-env && cd src/client && ng test --watch=false --browsers=ChromeHeadless",
    "client:test:watch": "npm run client:sync-env && cd src/client && ng test",
    "server:start": "cd src/server && nest start",
    "server:dev": "cd src/server && nest start --watch",
    "server:build": "cd src/server && nest build",
    "server:test": "cd src/server && jest"
  },
  "dependencies": {
    "@angular/animations": "^22.0.6",
    "@angular/common": "^22.0.6",
    "@angular/compiler": "^22.0.6",
    "@angular/core": "^22.0.6",
    "@angular/forms": "^22.0.6",
    "@angular/platform-browser": "^22.0.6",
    "@angular/platform-browser-dynamic": "^22.0.6",
    "@angular/router": "^22.0.6",
    "@nestjs/common": "^11.1.9",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.9",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/platform-express": "^11.1.9",
    "@nestjs/typeorm": "^11.0.0",
    "@ng-icons/bootstrap-icons": "^34.0.0",
    "@ng-icons/core": "^34.0.0",
    "@ng-icons/octicons": "^34.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "marked": "^18.0.6",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "typeorm": "^0.3.28",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^22.0.6",
    "@angular/cli": "^22.0.6",
    "@angular/compiler-cli": "^22.0.6",
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.9",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/express": "^5.0.6",
    "@types/jasmine": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "autoprefixer": "^10.5.2",
    "concurrently": "^9.2.1",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "^6.3.0",
    "jest": "^30.2.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "postcss": "^8.5.17",
    "source-map-support": "^0.5.21",
    "tailwindcss": "^4.3.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~6.0.3"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "http-proxy-middleware": "3.0.7",
    "webpack-dev-server": "6.0.0",
    "uuid": "11.1.1",
    "esbuild": "0.28.1"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-arm64-gnu": "4.3.2",
    "@tailwindcss/oxide-linux-x64-gnu": "4.3.2",
    "lightningcss-linux-arm64-gnu": "1.32.0",
    "lightningcss-linux-x64-gnu": "1.32.0"
  }
}
